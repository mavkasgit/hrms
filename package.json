{
  "name": "hrms",
  "private": true,
  "version": "1.0.0",
  "scripts": {
    "setup": "npm install && npm install --prefix frontend && echo 'Не забудьте установить зависимости Python!'",
    
    "predev": "npm run db:up",
    "dev": "concurrently --names \"DB,BACKEND,FRONTEND\" -c \"blue,green,yellow\" \"npm run db:logs\" \"npm run backend\" \"npm run frontend\"",
    
    "frontend": "npm --prefix frontend run dev",
    "backend": "cd backend && uvicorn app.main:app --host 0.0.0.0 --port 8000",

    "devkill": "npx kill-port 8000 2>nul & npx kill-port 5173 2>nul & echo Killed all dev servers",
    "devrestart": "npm run devkill && npm run dev",

    "db:up": "docker compose -f infra/docker-compose.dev.yml up -d",
    "db:down": "docker compose -f infra/docker-compose.dev.yml down",
    "db:logs": "docker compose -f infra/docker-compose.dev.yml logs -f",
    
    "db:migrate": "cd backend && alembic upgrade head",
    "db:makemigrate": "cd backend && alembic revision --autogenerate -m",
    
    "test:up": "docker compose -f infra/docker-compose.test.yml up -d --build",
    "test:down": "docker compose -f infra/docker-compose.test.yml down",
    "test:logs": "docker compose -f infra/docker-compose.test.yml logs -f",
    "test:e2e:smoke": "npx playwright test e2e/ui/structure-full-lifecycle.spec.ts e2e/ui/employees.spec.ts e2e/domain/vacation-periods-generation.spec.ts",
    "test:e2e:api": "npx playwright test e2e/api",
    "test:e2e:ui": "npx playwright test e2e/ui",
    "test:e2e:domain": "npx playwright test e2e/domain",
    "test:e2e:regression": "npx playwright test"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "concurrently": "^9.1.2"
  }
}
