{
  "name": "hrms",
  "private": true,
  "version": "1.0.0",
  "scripts": {
    "dev": "npm run install:all && npm run db:up && concurrently --names \"DB,BACKEND,FRONTEND\" -c \"blue,green,yellow\" --restart-tries 5 --restart-after 1000 \"npm run db:logs\" \"npm run backend\" \"npm run frontend\"",
    "install:all": "cd frontend && npm install",
    "db:up": "docker compose -f infra/docker-compose.dev.yml up -d",
    "db:logs": "docker compose -f infra/docker-compose.dev.yml logs -f",
    "db:down": "docker compose -f infra/docker-compose.dev.yml down",
    "backend": "cd backend && uvicorn app.main:app --reload --reload-dir app --reload-include \"*.py\" --host 0.0.0.0 --port 8000",
    "frontend": "cd frontend && npx vite --host 0.0.0.0 --port 5173",
    "migrate": "cd backend && alembic upgrade head",
    "makemigrate": "cd backend && alembic revision --autogenerate -m"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "concurrently": "^9.1.2"
  }
}
