{
  "name": "hrms",
  "private": true,
  "version": "1.0.0",
  "scripts": {
    "setup": "npm install && npm install --prefix frontend && echo 'Не забудьте установить зависимости Python!'",
    "predev": "npm run docker:dev:up && npm run db:wait && npm run dev:migrate",
    "dev": "concurrently --names \"DB,BACKEND,FRONTEND\" -c \"blue,green,yellow\" \"npm run docker:dev:logs\" \"npm run dev:backend\" \"npm run frontend\"",
    "frontend": "npm --prefix frontend run dev",
    "dev:backend": "node scripts/run.js run-backend",
    "dev:migrate": "node scripts/run.js run-migrate",
    "dev:kill": "node -e \"const cp=require('child_process');['8000','5173'].forEach((p)=>cp.spawnSync('npx',['kill-port',p],{stdio:'ignore',shell:true})); console.log('Dev ports cleanup done');\"",
    "dev:restart": "npm run dev:kill && npm run dev",
    "docker:dev:up": "docker compose --env-file .env.dev -f infra/compose/docker-compose.dev.yml up -d",
    "docker:dev:down": "docker compose --env-file .env.dev -f infra/compose/docker-compose.dev.yml down",
    "docker:dev:logs": "docker compose --env-file .env.dev -f infra/compose/docker-compose.dev.yml logs -f",
    "db:wait": "node scripts/run.js wait-for-postgres hrms-postgres hrms_user 60",
    "db:makemigrate": "cd backend && alembic revision --autogenerate -m",
    "docker:test:up": "docker compose --env-file .env.test -f infra/compose/docker-compose.test.yml up -d --build",
    "docker:test:down": "docker compose --env-file .env.test -f infra/compose/docker-compose.test.yml down",
    "docker:test:logs": "docker compose --env-file .env.test -f infra/compose/docker-compose.test.yml logs -f",
    "test:tunnel:up": "docker compose --env-file .env.test -f infra/compose/docker-compose.test.yml --profile tunnel up -d --build",
    "docker:prod:up": "docker compose --env-file .env.prod -f infra/compose/docker-compose.prod.yml up -d --build",
    "docker:prod:down": "docker compose --env-file .env.prod -f infra/compose/docker-compose.prod.yml down",
    "docker:prod:logs": "docker compose --env-file .env.prod -f infra/compose/docker-compose.prod.yml logs -f",
    "prod:tunnel:up": "docker compose --env-file .env.prod -f infra/compose/docker-compose.prod.yml --profile tunnel up -d --build",
    "db:up": "npm run docker:dev:up",
    "db:down": "npm run docker:dev:down",
    "db:logs": "npm run docker:dev:logs",
    "backend": "npm run dev:backend",
    "db:migrate": "npm run dev:migrate",
    "test:up": "npm run docker:test:up",
    "test:down": "npm run docker:test:down",
    "test:logs": "npm run docker:test:logs",
    "prod:up": "npm run docker:prod:up",
    "prod:down": "npm run docker:prod:down",
    "prod:logs": "npm run docker:prod:logs",
    "test:e2e:smoke": "npx playwright test e2e/ui/structure-full-lifecycle.spec.ts e2e/ui/employees.spec.ts e2e/domain/vacation-periods-generation.spec.ts",
    "test:e2e:api": "npx playwright test e2e/api",
    "test:e2e:ui": "npx playwright test e2e/ui",
    "test:e2e:domain": "npx playwright test e2e/domain",
    "test:e2e:regression": "npx playwright test"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "concurrently": "^9.1.2",
    "cross-env": "^7.0.3"
  }
}
