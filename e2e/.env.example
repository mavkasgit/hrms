# E2E environment template (copy to e2e/.env — not committed if secrets).
# Dev defaults only; do not put production credentials here.

# App under test
E2E_BASE_URL=http://localhost:5173
E2E_API_URL=http://localhost:8000/api

# Admin for setup/auth (backend DEV_BYPASS_AUTH accepts password "dev")
E2E_ADMIN_USERNAME=admin
E2E_ADMIN_PASSWORD=dev

# Browser mode: cdp | headless | headed | managed
# managed/headless/headed — Playwright launches Chromium (required for multi-worker)
# cdp — single shared Chrome; workers must stay 1 (fail-fast if PW_WORKERS>1)
E2E_BROWSER_MODE=managed

# Optional multi-worker (opt-in; default workers=1 when unset)
# PW_WORKERS=2

# Optional Chrome path (Windows example)
# CHROME_PATH=C:\Program Files\Google\Chrome\Application\chrome.exe

# CDP (only when E2E_BROWSER_MODE=cdp and workers=1)
# BROWSER_PORT=9222
# REMOTE_CHROME_HOST=localhost
