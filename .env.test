# Test environment
# All traffic goes through nginx on port 8080

ENV=test

# === BASE URL (единая точка входа через nginx) ===
# Change to LAN IP for network access, e.g.:
# BASE_URL=http://localhost:8080
BASE_URL=http://192.168.100.200:8080
PUBLIC_URL=http://192.168.100.200:8080

# === Database ===
POSTGRES_USER=hrms_user
POSTGRES_PASSWORD=hrms_pass_test
POSTGRES_DB=hrms_test
DATABASE_URL=postgresql+asyncpg://hrms_user:hrms_pass_test@postgres:5432/hrms_test

# === OnlyOffice ===
ONLYOFFICE_ENABLED=true
ONLYOFFICE_JWT_SECRET=onlyoffice-test-secret
ONLYOFFICE_PUBLIC_URL=${PUBLIC_URL}/onlyoffice
ONLYOFFICE_INTERNAL_URL=http://nginx/onlyoffice

# === App ===
BACKEND_INTERNAL_CALLBACK_URL=http://backend:8000
APP_PUBLIC_URL=http://backend:8000

# === LocalTunnel ===
LOCALTUNNEL_SUBDOMAIN=hrms-test-7q2k9m4x

# === Frontend auth mode (dev/test enables bypass buttons) ===
VITE_AUTH_MODE=test
