# Dev environment
# Backend/frontend run locally, only postgres + onlyoffice run in Docker

ENV=dev

# === BASE URL (frontend dev server) ===
BASE_URL=http://localhost:5173
PUBLIC_URL=http://localhost:5173

# === Database ===
POSTGRES_USER=hrms_user
POSTGRES_PASSWORD=hrms_pass
POSTGRES_DB=hrms_dev
DEV_POSTGRES_PORT=5435
DATABASE_URL=postgresql+asyncpg://hrms_user:hrms_pass@localhost:5435/hrms_dev

# === OnlyOffice ===
ONLYOFFICE_ENABLED=true
ONLYOFFICE_JWT_SECRET=onlyoffice-dev-secret-change-me
ONLYOFFICE_PUBLIC_URL=http://localhost:8085
ONLYOFFICE_INTERNAL_URL=http://localhost:8085

# === App ===
# URL that ONLYOFFICE container can reach to download/upload docs from backend
BACKEND_INTERNAL_CALLBACK_URL=http://host.docker.internal:8000
APP_PUBLIC_URL=http://host.docker.internal:8000

JWT_SECRET_KEY=shared-sso-secret-key-12345

# === Frontend auth mode (dev/test enables bypass buttons) ===
VITE_AUTH_MODE=dev
TZ=Europe/Moscow


# === Telegram Login (Widget / bot) — token is set via /settings/users UI (system_settings.telegram.bot_token) ===
TELEGRAM_BOT_USERNAME=ktm2000_bot
TELEGRAM_ALLOW_JIT=false
TELEGRAM_UPDATES_POLLING=true
# unused reserved — origin check not enforced
TELEGRAM_ALLOWED_ORIGINS=http://localhost:5173
