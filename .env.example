# HRMS environment reference
#
# Copy the relevant section into .env.dev, .env.test, or .env.prod.
# Real .env.* files are ignored by git.
#
# Architecture:
# - prod: nginx on 80/443
# - test: nginx on 8080
# - dev: run Vite directly (no nginx required)
#
# Inside Docker, all services use standard ports:
# - frontend:  3000
# - backend:   8000
# - postgres:  5432
# - onlyoffice: 80
#
# URL roles:
# - BASE_URL / PUBLIC_URL: browser/public URL (what users open)
# - ONLYOFFICE_PUBLIC_URL: browser URL for Document Server (usually BASE_URL + /onlyoffice)
# - BACKEND_INTERNAL_CALLBACK_URL: internal URL ONLYOFFICE uses for callbacks/file download
# - APP_PUBLIC_URL: legacy fallback for callback URL (kept for backward compatibility)

# -----------------------------------------------------------------------------
# Telegram Login (OIDC + Bot) — shared across envs; override per .env.*
# -----------------------------------------------------------------------------
# TELEGRAM_BOT_TOKEN — BotFather bot token (secret, never frontend)
# TELEGRAM_BOT_USERNAME — bot username without @ (deep links / button)
# TELEGRAM_OIDC_CLIENT_ID / SECRET — Telegram Web Login / OIDC client
# TELEGRAM_OIDC_REDIRECT_URI — backend OIDC callback URL
# TELEGRAM_ALLOWED_ORIGINS — comma-separated origins for login widget
# TELEGRAM_ALLOW_JIT — if true, auto-create User on first TG login
# TELEGRAM_DEFAULT_ROLE — role for JIT users (admin|viewer)
# TELEGRAM_BOT_CHALLENGE_TTL_SECONDS — bot deep-link challenge TTL
# TELEGRAM_AUTH_DATE_MAX_AGE_SECONDS — max age for legacy widget auth_date
# TELEGRAM_WEBHOOK_SECRET — X-Telegram-Bot-Api-Secret-Token expected value

TELEGRAM_BOT_TOKEN=
TELEGRAM_BOT_USERNAME=
TELEGRAM_OIDC_CLIENT_ID=
TELEGRAM_OIDC_CLIENT_SECRET=
TELEGRAM_OIDC_REDIRECT_URI=
TELEGRAM_ALLOWED_ORIGINS=http://localhost:5173
TELEGRAM_ALLOW_JIT=false
TELEGRAM_DEFAULT_ROLE=viewer
TELEGRAM_BOT_CHALLENGE_TTL_SECONDS=300
TELEGRAM_AUTH_DATE_MAX_AGE_SECONDS=86400
TELEGRAM_WEBHOOK_SECRET=
# Dev: true = backend pulls Telegram updates (getUpdates), real /start in TG app, no ngrok
TELEGRAM_UPDATES_POLLING=true
# Fake QR "confirm as username" — leave false; use real bot instead
TELEGRAM_DEV_FAKE_CONFIRM=false

# -----------------------------------------------------------------------------
# .env.dev  (backend/frontend local, postgres+onlyoffice in Docker)
# -----------------------------------------------------------------------------

ENV=dev
BASE_URL=http://localhost:5173
PUBLIC_URL=http://localhost:5173
POSTGRES_USER=
POSTGRES_PASSWORD=
POSTGRES_DB=
DATABASE_URL=postgresql+asyncpg://hrms_user:hrms_pass@localhost:5432/hrms_dev
ONLYOFFICE_ENABLED=true
ONLYOFFICE_JWT_SECRET=
ONLYOFFICE_PUBLIC_URL=http://localhost:8085
ONLYOFFICE_INTERNAL_URL=http://localhost:8085
BACKEND_INTERNAL_CALLBACK_URL=http://host.docker.internal:8000
APP_PUBLIC_URL=http://host.docker.internal:8000
TZ=Europe/Moscow

# -----------------------------------------------------------------------------
# .env.test  (nginx port 8080)
# -----------------------------------------------------------------------------

ENV=test
BASE_URL=http://192.168.100.200:8080
PUBLIC_URL=http://192.168.100.200:8080
POSTGRES_USER=
POSTGRES_PASSWORD=
POSTGRES_DB=
DATABASE_URL=
ONLYOFFICE_ENABLED=true
ONLYOFFICE_JWT_SECRET=
ONLYOFFICE_PUBLIC_URL=${PUBLIC_URL}/onlyoffice
ONLYOFFICE_INTERNAL_URL=http://nginx/onlyoffice
BACKEND_INTERNAL_CALLBACK_URL=http://backend:8000
APP_PUBLIC_URL=http://backend:8000
LOCALTUNNEL_SUBDOMAIN=
TZ=Europe/Moscow

# -----------------------------------------------------------------------------
# .env.prod  (nginx port 80)
# -----------------------------------------------------------------------------

ENV=prod
BASE_URL=http://192.168.100.200
PUBLIC_URL=http://192.168.100.200
SECRET_KEY=
POSTGRES_USER=
POSTGRES_PASSWORD=
POSTGRES_DB=
DATABASE_URL=
ONLYOFFICE_ENABLED=true
ONLYOFFICE_JWT_SECRET=
ONLYOFFICE_PUBLIC_URL=${PUBLIC_URL}/onlyoffice
ONLYOFFICE_INTERNAL_URL=http://nginx/onlyoffice
BACKEND_INTERNAL_CALLBACK_URL=http://backend:8000
APP_PUBLIC_URL=${PUBLIC_URL}
TELEGRAM_PUBLIC_APP_URL=${PUBLIC_URL}
PROD_POSTGRES_DATA_PATH=
LOCALTUNNEL_SUBDOMAIN=
TZ=Europe/Moscow
