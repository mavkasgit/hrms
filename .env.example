# HRMS environment reference
#
# This file documents every environment file used by the project.
# Copy the relevant section into `.env.dev`, `.env.test`, or `.env.prod`.
# Real `.env.*` files are ignored by git.
#
# Important OnlyOffice rule:
# `APP_PUBLIC_URL` and `ONLYOFFICE_PUBLIC_URL` must be the same URL that the
# browser uses to open HRMS. For local network access, this is usually
# `http://<LAN_IP>:<FRONTEND_PORT>`.


# -----------------------------------------------------------------------------
# .env.dev
# -----------------------------------------------------------------------------
# Purpose:
# - Local development.
# - Docker runs only PostgreSQL and OnlyOffice.
# - Backend runs on the host with `npm run backend`.
# - Frontend runs on the host with `npm run frontend`.
#
# Default URLs:
# - Frontend: http://localhost:5173
# - Backend: http://localhost:8000
# - PostgreSQL: localhost:5432
# - OnlyOffice: http://localhost:8085
#
# Data safety:
# - Dev PostgreSQL uses `data/postgres-dev`.
# - Do not point dev and prod to the same PostgreSQL data directory.

ENV=dev
POSTGRES_USER=replace-with-dev-db-user
POSTGRES_PASSWORD=replace-with-dev-db-password
POSTGRES_DB=hrms_dev
DEV_POSTGRES_PORT=5432
DEV_POSTGRES_DATA_PATH=../data/postgres-dev
BACKEND_PORT=8000
FRONTEND_PORT=5173
DEV_ONLYOFFICE_PORT=8085
DATABASE_URL=postgresql+asyncpg://replace-with-dev-db-user:replace-with-dev-db-password@localhost:5432/hrms_dev
ONLYOFFICE_ENABLED=true
ONLYOFFICE_JWT_SECRET=replace-with-dev-onlyoffice-secret
ONLYOFFICE_PUBLIC_URL=http://localhost:8085
ONLYOFFICE_INTERNAL_URL=http://localhost:8085
APP_PUBLIC_URL=http://host.docker.internal:8000


# -----------------------------------------------------------------------------
# .env.test
# -----------------------------------------------------------------------------
# Purpose:
# - Full Docker test stack.
# - PostgreSQL, backend, frontend, and OnlyOffice all run in Docker.
#
# Default URLs:
# - Frontend: http://localhost:5174
# - Backend: http://localhost:8001
# - PostgreSQL: localhost:5433
# - OnlyOffice direct port: http://localhost:8086
#
# Local network:
# - Set `LAN_PUBLIC_URL` to the IP of the computer that starts Docker.
# - Other devices should open the same URL in the browser.
# - Example: `LAN_PUBLIC_URL=http://<LAN_IP>:5174`.
#
# Localtunnel:
# - Kept as a temporary option: `npm run test:tunnel:up`.
# - It is not reliable for OnlyOffice websocket/static traffic; LAN is preferred.

ENV=test
POSTGRES_USER=replace-with-test-db-user
POSTGRES_PASSWORD=replace-with-test-db-password
POSTGRES_DB=hrms_test
TEST_POSTGRES_PORT=5433
TEST_BACKEND_PORT=8001
TEST_FRONTEND_PORT=5174
TEST_ONLYOFFICE_PORT=8086
ONLYOFFICE_ENABLED=true
ONLYOFFICE_JWT_SECRET=replace-with-test-onlyoffice-secret
LAN_PUBLIC_URL=http://<LAN_IP>:5174
ONLYOFFICE_PUBLIC_URL=http://<LAN_IP>:5174
ONLYOFFICE_INTERNAL_URL=http://onlyoffice:80
APP_PUBLIC_URL=http://<LAN_IP>:5174
LOCALTUNNEL_SUBDOMAIN=replace-with-test-localtunnel-subdomain


# -----------------------------------------------------------------------------
# .env.prod
# -----------------------------------------------------------------------------
# Purpose:
# - Full Docker production-like stack.
# - PostgreSQL, backend, frontend, and OnlyOffice all run in Docker.
#
# Default URLs:
# - Frontend: http://localhost:5175
# - Backend: http://localhost:8002
# - PostgreSQL: localhost:5434 bound to 127.0.0.1 by default
# - OnlyOffice direct port: http://localhost:8087
#
# Data safety:
# - Existing installation currently stores prod data in `data/postgres`.
# - Dev must not use `data/postgres`.
# - For a new clean production install, prefer `data/postgres-prod`.
# - Do not change `PROD_POSTGRES_DATA_PATH` on an existing install unless the
#   old cluster has been copied/migrated while PostgreSQL is stopped.
#
# Local network:
# - Set `LAN_PUBLIC_URL` to the IP of the computer that starts Docker.
# - Example: `LAN_PUBLIC_URL=http://<LAN_IP>:5175`.

ENV=prod
POSTGRES_USER=replace-with-prod-db-user
POSTGRES_PASSWORD=replace-with-prod-db-password
POSTGRES_DB=hrms_prod
PROD_POSTGRES_BIND=127.0.0.1
PROD_POSTGRES_PORT=5434
PROD_BACKEND_PORT=8002
PROD_FRONTEND_PORT=5175
PROD_ONLYOFFICE_PORT=8087
PROD_POSTGRES_DATA_PATH=../data/postgres
SECRET_KEY=replace-with-prod-secret-key
ONLYOFFICE_ENABLED=true
ONLYOFFICE_JWT_SECRET=replace-with-prod-onlyoffice-secret
LAN_PUBLIC_URL=http://<LAN_IP>:5175
ONLYOFFICE_PUBLIC_URL=http://<LAN_IP>:5175
ONLYOFFICE_INTERNAL_URL=http://onlyoffice:80
APP_PUBLIC_URL=http://<LAN_IP>:5175
LOCALTUNNEL_SUBDOMAIN=replace-with-prod-localtunnel-subdomain
